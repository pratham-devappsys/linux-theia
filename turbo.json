{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "clean": {
            "outputs": [],
            "dependsOn": ["^clean"],
            "cache": false
        },
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["lib/**"],
            "cache":true
        },
        "start": {
            "dependsOn": ["^build"],
            "outputs": [],
            "cache": false
        },
        "watch": {
            "cache": false,
            "dependsOn": [],
            "outputs": ["lib/**"]
        }
    }
}
